#include <iostream>
using namespace std;

class Product
{
private:
    int quantity;

public:
    Product(int q)
    {
        quantity = q;
        cout << "Parameterized Constructor Called\n";
    }

    Product(const Product &p)
    {
        quantity = p.quantity;
        cout << "Copy Constructor Called\n";
    }

    Product operator+(const Product &p)
    {
        Product temp(quantity + p.quantity);
        return temp;
    }

    ~Product()
    {
        cout << "Destructor Called\n";
    }

    void display()
    {
        cout << "Quantity = " << quantity << endl;
    }
};

int main()
{
    Product p1(50);
    Product p2(30);

    Product p3 = p1;
    Product p4 = p1 + p2;

    p4.display();

    return 0;
}
