#include <iostream>
using namespace std;

class Account
{
private:
    int accNo;
    string name;
    double balance;

public:
    Account()
    {
        accNo = 0;
        name = "Unknown";
        balance = 0;
    }

    Account(int a)
    {
        accNo = a;
        name = "Unknown";
        balance = 0;
    }

    Account(int a, string n, double b)
    {
        accNo = a;
        name = n;
        balance = b;
    }

    Account(const Account &obj)
    {
        accNo = obj.accNo;
        name = obj.name;
        balance = obj.balance;
    }

    Account operator+(double amount)
    {
        Account temp(*this);
        temp.balance += amount;
        return temp;
    }

    Account operator-(double amount)
    {
        Account temp(*this);
        temp.balance -= amount;
        return temp;
    }

    ~Account()
    {
        cout << "Account Closed\n";
    }
};
