#include <iostream>
#include <cstring>
using namespace std;

class Product
{
private:
    int productID;
    char *name;
    int quantity;

public:
    Product(int id, const char *n, int q)
    {
        productID = id;
        quantity = q;

        name = new char[strlen(n) + 1];
        strcpy(name, n);

        cout << "Parameterized Constructor Called\n";
    }

    Product(const Product &p)
    {
        productID = p.productID;
        quantity = p.quantity;

        name = new char[strlen(p.name) + 1];
        strcpy(name, p.name);

        cout << "Copy Constructor Called\n";
    }

    Product operator+(const Product &p)
    {
        Product temp(productID, name, quantity + p.quantity);
        return temp;
    }

    ~Product()
    {
        delete[] name;
        cout << "Destructor Called\n";
    }

    void display()
    {
        cout << productID << " "
             << name << " "
             << quantity << endl;
    }
};

int main()
{
    Product p1(101, "Laptop", 50);
    Product p2 = p1;
    Product p3(102, "Laptop", 30);

    Product p4 = p1 + p3;

    p4.display();

    return 0;
}
